<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Todo App</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var excludedControllers = new[] { "Home", "Register", "Login" };
}

<body>
    <div class="d-flex" id="wrapper">

        @* الـ Sidebar بيظهر فقط في صفحات المهام وليس في صفحة الهبوط أو التسجيل *@
        @if (!excludedControllers.Contains(currentController))
        {
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

            <div class="border-end bg-white" id="sidebar-wrapper" style="width: 280px; min-height: 100vh;">

                <div class="sidebar-heading p-3">
                    <i class="bi bi-list fs-4"></i>
                    <span class="ms-2 fw-bold">Menu</span>
                </div>

                <div class="list-group list-group-flush">

                    <a class="list-group-item list-group-item-action p-3 border-0 @(currentAction == "Index" ? "active" : "")"
                           asp-controller="ToDo" asp-action="Index">
                        <i class="bi bi-brightness-high me-2"></i> My Day
                    </a>

                    <a class="list-group-item list-group-item-action p-3 border-0 @(currentAction == "Important" ? "active" : "")"
                           asp-controller="ToDo" asp-action="Important">
                        <i class="bi bi-star me-2"></i> Important
                    </a>

                    <a class="list-group-item list-group-item-action p-3 border-0 @(currentAction == "CompletedTasks" ? "active" : "")"
                           asp-controller="ToDo" asp-action="CompletedTasks">
                        <i class="bi bi-check2-circle me-2"></i> Completed
                    </a>

                    <a class="list-group-item list-group-item-action p-3 border-0 @(currentAction == "AllTasks" ? "active" : "")"
                           asp-controller="ToDo" asp-action="AllTasks">
                        <i class="bi bi-list-task me-2"></i> All Tasks
                    </a>

                </div>
            </div>
        }

        <div id="page-content-wrapper" class="flex-grow-1 bg-light d-flex flex-column" style="min-height: 100vh;">
            
            <div class="container-fluid p-4 flex-grow-1">
                <main role="main">
                    @RenderBody()
                </main>
            </div>

            <footer class="border-top footer text-muted py-2 bg-white">
                <div class="container-fluid text-center">
                    <small>&copy; 2026 - ToDo App</small>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>