@model IEnumerable<to_do_list_with_asp.net_.Models.todotask>

@{
    ViewData["Title"] = "My Day";
    var current = ViewContext.RouteData.Values["action"]?.ToString();
}

<div class="container-fluid">
    <div class="row">


        <!-- MAIN CONTENT -->
        <div class="col-md-9 col-lg-10">

            <!-- HEADER -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    @if (Context.Session.GetString("UserName") != null)
                    {
                    <h2 class="fw-bold mb-0">

                            <i class="bi bi-brightness-high text-warning"></i>  Welcome, <strong>@Context.Session.GetString("UserName")
                    </h2>
}
                    <p class="text-muted small">@DateTime.Now.ToString("D")</p>
                </div>

                <form asp-controller="ToDo" asp-action="Logout" method="post">
                    <button type="submit" class="btn btn-danger btn-sm">
                        Logout
                    </button>
                </form>
            </div>

            <!-- ADD TASK -->
            <form asp-controller="ToDo" asp-action="AddTask" method="post">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-2 d-flex align-items-center">
                        <i class="bi bi-circle text-primary mx-3"></i>

                        <input type="text"
                               name="title"
                               class="form-control border-0 shadow-none"
                               placeholder="Add a task"
                               required>
                    </div>

                    <div class="card-footer bg-white border-0 d-flex justify-content-end pb-3">
                        <button type="submit" class="btn btn-outline-primary btn-sm px-3">
                            Add
                        </button>
                    </div>
                </div>
            </form>

            <!-- TASK LIST -->
            <div class="todo-list">

                @foreach (var task in Model)
                {
                    <div class="card shadow-sm border-0 mb-2">

                        <div class="card-body p-3 d-flex align-items-center justify-content-between">
                            <!-- TITLE -->
                            <div class="ms-2">
                                <div class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                                    @task.Title
                                </div>
                            </div>
                            <!-- LEFT SIDE ACTIONS -->
                            <div class="d-flex align-items-center gap-2">

                                <!-- COMPLETE / INCOMPLETE -->
                                <form asp-action="ToggleComplete"
                                      asp-route-id="@task.Id"
                                      asp-route-returnUrl="@Context.Request.Path"
                                      method="post">

                                    <button type="submit"
                                            class="btn btn-sm @(task.IsCompleted ? "btn-success" : "btn-outline-success")">

                                        @if (task.IsCompleted)
                                        {
                                            <span>Mark not Complete</span>
                                        }
                                        else
                                        {
                                            <span>Mark Complete</span>
                                        }

                                    </button>
                                </form>

                                <!-- IMPORTANT -->
                                <a asp-action="ToggleImportant"
                                       asp-route-id="@task.Id"
                                       asp-route-returnUrl="@Context.Request.Path"
                                       class="text-decoration-none">
                                    <i class="bi @(task.IsImportant ? "bi-star-fill text-primary" : "bi-star text-primary") fs-5"></i>
                                </a>

                                <!-- EDIT -->
                                <a asp-action="Edit"
                                       asp-route-id="@task.Id"
                                       asp-route-returnUrl="@Context.Request.Path"
                                       class="text-decoration-none text-warning">
                                    <i class="bi bi-pencil-square fs-5"></i>
                                </a>

                                <!-- DELETE -->
                                <form asp-action="Delete"
                                      asp-route-id="@task.Id"
                                      asp-route-returnUrl="@Context.Request.Path"
                                      method="post"
                                      class="d-inline">

                                    <button type="submit"
                                            class="btn btn-link text-danger p-0"
                                            onclick="return confirm('Delete this task?')">
                                        <i class="bi bi-trash fs-5"></i>
                                    </button>

                                </form>

                            </div>



                        </div>

                    </div>
                }

            </div>

        </div>

    </div>
</div>