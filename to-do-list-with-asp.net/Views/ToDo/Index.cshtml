@model IEnumerable<to_do_list_with_asp.net_.Models.todotask>

@{
    ViewData["Title"] = "My Day";
}

<div class="main-content-area">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <div>
            <h2 class="fw-bold mb-0"><i class="bi bi-brightness-high text-warning"></i> My Day</h2>
            <p class="text-muted small">@DateTime.Now.ToString("D")</p>
        </div>
    </div>

   
    <form asp-controller="ToDo" asp-action="AddTask" method="post">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-2 d-flex align-items-center">
                <i class="bi bi-circle text-primary mx-3"></i>
                <input type="text" name="title" class="form-control border-0 shadow-none" placeholder="Add a task" required>
            </div>
            <div class="card-footer bg-white border-0 d-flex justify-content-end pb-3">
                <button type="submit" class="btn btn-outline-primary btn-sm px-3">Add</button>
            </div>
        </div>
    </form>

 
 
    <div class="todo-list">
        @foreach (var task in Model)
        {
            <div class="card shadow-sm border-0 mb-2">
                <div class="card-body p-3 d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <a asp-action="ToggleComplete" asp-route-id="@task.Id" class="text-decoration-none me-3">
                            <i class="bi @(task.IsCompleted ? "bi-check-circle-fill text-primary" : "bi-circle text-primary") fs-5"></i>
                        </a>

                        <div>
                            <div class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                                @task.Title
                            </div>
                            <small class="text-muted" style="font-size: 0.7rem;">Tasks</small>
                        </div>
                    </div>

                    <a asp-action="ToggleImportant" asp-route-id="@task.Id" class="text-decoration-none">
                        <i class="bi @(task.IsImportant ? "bi-star-fill text-primary" : "bi-star text-primary") fs-5"></i>
                    </a>
                </div>
            </div>
        }
    </div>

</div>